generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth ─────────────────────────────────────────────────
model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         String      @default("SALES") // "ADMIN" | "SALES"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  quotations   Quotation[]
  invoices     Invoice[]
  billings     Billing[]
  receipts     Receipt[]
}

// ─── Products ─────────────────────────────────────────────
model Product {
  id             String          @id @default(cuid())
  nameTh         String
  nameEn         String?
  unit           String
  pricePerUnit   Float
  stockQuantity  Float           @default(0)
  lowStockThreshold Float        @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  quotationItems QuotationItem[]
  invoiceItems   InvoiceItem[]
  billingItems   BillingItem[]
  receiptItems   ReceiptItem[]
}

// ─── Company Settings ──────────────────────────────────────
model Company {
  id        String   @id @default(cuid())
  nameTh    String   @default("บริษัท เบลสมี ท็อปปิ้ง จำกัด")
  nameEn    String?
  address   String   @default("")
  taxId     String   @default("")
  phone     String   @default("")
  email     String   @default("")
  logoPath  String?
  termsText String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Clients ───────────────────────────────────────────────
model Client {
  id            String   @id @default(cuid())
  name          String
  address       String?
  taxId         String?
  phone         String?
  email         String?
  contactPerson String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── QT Numbering sequence ─────────────────────────────────
model QTSequence {
  id      String @id @default(cuid())
  year    Int    @unique
  lastSeq Int    @default(0)
}

// ─── Quotation ─────────────────────────────────────────────
model Quotation {
  id              String  @id @default(cuid())
  qtNumber        String  @unique
  status          String  @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED | EXPIRED
  createdById     String
  createdBy       User    @relation(fields: [createdById], references: [id])

  customerName    String
  customerAddress String?
  customerTaxId   String?
  customerPhone   String?
  customerEmail   String?
  customerContact String?

  issueDate    DateTime @default(now())
  validUntil   DateTime
  deliveryDate DateTime?

  subtotal   Float  @default(0)
  vatRate    Float  @default(7)
  vatAmount  Float  @default(0)
  grandTotal Float  @default(0)
  currency   String @default("THB")

  notes         String?
  termsSnapshot String?
  pdfPath       String?

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     QuotationItem[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

// ─── Quotation Line Items ───────────────────────────────────
model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])

  productNameTh String
  productNameEn String?
  unit          String
  quantity      Float
  unitPrice     Float
  lineTotal     Float

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── INV Numbering sequence ────────────────────────────────
model INVSequence {
  id      String @id @default(cuid())
  year    Int    @unique
  lastSeq Int    @default(0)
}

// ─── Invoice ───────────────────────────────────────────────
model Invoice {
  id              String  @id @default(cuid())
  invNumber       String  @unique
  status          String  @default("UNPAID") // UNPAID | PAID | OVERDUE | CANCELLED
  createdById     String
  createdBy       User    @relation(fields: [createdById], references: [id])

  quotationId     String? @unique
  quotationNumber String?

  customerName    String
  customerAddress String?
  customerTaxId   String?
  customerPhone   String?
  customerEmail   String?
  customerContact String?

  issueDate    DateTime @default(now())
  dueDate      DateTime?
  deliveryDate DateTime?

  subtotal   Float  @default(0)
  vatRate    Float  @default(7)
  vatAmount  Float  @default(0)
  grandTotal Float  @default(0)
  currency   String @default("THB")

  notes         String?
  termsSnapshot String?
  pdfPath       String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     InvoiceItem[]
  receipts  Receipt[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

// ─── Invoice Line Items ─────────────────────────────────────
model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])

  productNameTh String
  productNameEn String?
  unit          String
  quantity      Float
  unitPrice     Float
  lineTotal     Float

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── BN Numbering sequence ────────────────────────────────
model BNSequence {
  id      String @id @default(cuid())
  year    Int    @unique
  lastSeq Int    @default(0)
}

// ─── RC Numbering sequence ────────────────────────────────
model RCSequence {
  id      String @id @default(cuid())
  year    Int    @unique
  lastSeq Int    @default(0)
}

// ─── Billing Note ──────────────────────────────────────────
model Billing {
  id              String  @id @default(cuid())
  bnNumber        String  @unique
  status          String  @default("PENDING") // PENDING | COLLECTED | CANCELLED
  createdById     String
  createdBy       User    @relation(fields: [createdById], references: [id])

  invoiceId       String? @unique
  invoiceNumber   String?

  customerName    String
  customerAddress String?
  customerTaxId   String?
  customerPhone   String?
  customerEmail   String?
  customerContact String?

  issueDate    DateTime @default(now())
  dueDate      DateTime?

  subtotal   Float  @default(0)
  vatRate    Float  @default(7)
  vatAmount  Float  @default(0)
  grandTotal Float  @default(0)
  currency   String @default("THB")

  notes         String?
  termsSnapshot String?
  pdfPath       String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     BillingItem[]
  receipts  Receipt[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

// ─── Billing Line Items ─────────────────────────────────────
model BillingItem {
  id          String   @id @default(cuid())
  billingId   String
  billing     Billing  @relation(fields: [billingId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])

  productNameTh String
  productNameEn String?
  unit          String
  quantity      Float
  unitPrice     Float
  lineTotal     Float

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Receipt ───────────────────────────────────────────────
model Receipt {
  id              String  @id @default(cuid())
  rcNumber        String  @unique
  status          String  @default("WAITING") // WAITING | ISSUED | CANCELLED
  createdById     String
  createdBy       User    @relation(fields: [createdById], references: [id])

  invoiceId       String? @unique
  invoiceNumber   String?
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  billingId       String? @unique
  billingNumber   String?
  billing         Billing? @relation(fields: [billingId], references: [id])

  customerName    String
  customerAddress String?
  customerTaxId   String?
  customerPhone   String?
  customerEmail   String?
  customerContact String?

  issueDate    DateTime @default(now())

  subtotal   Float  @default(0)
  vatRate    Float  @default(7)
  vatAmount  Float  @default(0)
  grandTotal Float  @default(0)
  currency   String @default("THB")

  notes         String?
  termsSnapshot String?
  pdfPath       String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     ReceiptItem[]

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

// ─── Receipt Line Items ─────────────────────────────────────
model ReceiptItem {
  id          String   @id @default(cuid())
  receiptId   String
  receipt     Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])

  productNameTh String
  productNameEn String?
  unit          String
  quantity      Float
  unitPrice     Float
  lineTotal     Float

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
